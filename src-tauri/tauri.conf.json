{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CorvusDB",
  "version": "0.1.0",
  "identifier": "com.corvusdb.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CorvusDB",
        "width": 1300,
        "height": 920,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/ico.png",
      "icons/icon.png"
    ]
  }
}
